# ElevenLabs Conversational AI — required for the live demo call button
# Get these from https://elevenlabs.io/app/conversational-ai
ELEVENLABS_AGENT_ID=your-agent-id-here
ELEVENLABS_API_KEY=your-api-key-here

# Resend — required for the contact form to send emails
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx
# Email address where form submissions are sent
CONTACT_EMAIL=you@yourdomain.com
